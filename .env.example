# Forge — environment template. Copy to `.env` and fill in the keys you use.
#   cp .env.example .env
# `.env` is gitignored. Forge loads it automatically (see forge/_env.py); values
# already present in the real environment are NOT overridden.

# --- Provider API keys (read by the provider adapters in forge/providers/) ----

# OpenAI (also used for the default `clarifier` role). Format: sk-...
OPENAI_API_KEY=

# Anthropic (default `architect` role). Format: sk-ant-...
ANTHROPIC_API_KEY=

# DeepSeek (OpenAI-compatible API). Format: sk-...
DEEPSEEK_API_KEY=

# --- Optional base-URL overrides ----------------------------------------------
# These are normally set per-role in .forge/config.yaml, not here, but env vars
# are handy for quick experiments / proxies. Leave unset to use the defaults.

# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama runs locally and needs no API key — only a base URL (default below).
# OLLAMA_BASE_URL=http://localhost:11434
